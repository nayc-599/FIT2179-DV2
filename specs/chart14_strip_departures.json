{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Total departures from Australia by country",
    "subtitle": "Each dot = one country. Total 2004\u201305 to 2024\u201325. Hover for details.",
    "font": "DM Sans",
    "subtitleFontSize": 12,
    "subtitleColor": "#b8d0e8"
  },
  "width": "container",
  "height": 400,
  "data": {"url": "data/chart_strip_departures_all.csv"},
  "layer": [
    {
      "mark": {"type": "tick", "thickness": 1, "opacity": 0.12, "color": "rgba(255,255,255,0.2)"},
      "encoding": {
        "x": {
          "field": "continent",
          "type": "ordinal",
          "sort": ["Asia","Europe","Oceania","Americas","Africa","Middle East"]
        },
        "y": {"field": "value", "type": "quantitative", "axis": {"grid": false, "title": null}, "scale": {"type": "log"}}
      }
    },
    {
      "mark": {"type": "point", "filled": true, "size": 60, "opacity": 0.7},
      "encoding": {
        "x": {
          "field": "continent",
          "type": "ordinal",
          "sort": ["Asia","Europe","Oceania","Americas","Africa","Middle East"],
          "title": "Continent",
          "axis": {"labelAngle": 0}
        },
        "y": {
          "field": "value",
          "type": "quantitative",
          "title": "Total departures",
          "axis": null
        },
        "color": {
          "field": "continent",
          "type": "nominal",
          "legend": {"orient": "bottom", "title": "Continent"},
          "scale": {
            "domain": ["Asia","Europe","Oceania","Americas","Africa","Middle East"],
            "range": ["#ff6eb4","#54a0ff","#16a085","#7d3c98","#d35400","#d4ac0d"]
          }
        },
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "continent", "title": "Continent"},
          {"field": "value", "title": "Total departures", "format": ","}
        ]
      }
    }
  ],
  "config": {
    "background": "transparent",
    "view": {"stroke": null},
    "font": "DM Sans",
    "axis": {"labelFontSize": 11, "titleFontSize": 12}
  }
}