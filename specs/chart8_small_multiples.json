{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Departures over time in the three largest states",
    "subtitle": "New South Wales, Victoria, and Queensland compared on the same scale",
    "font": "DM Sans",
    "subtitleFontSize": 12,
    "subtitleColor": "#8aa4c0"
  },
  "height": 280,
  "data": {
    "url": "data/chart8_state_timeseries.csv",
    "format": {"type": "csv"}
  },
  "transform": [
    {"filter": {"field": "state", "oneOf": ["NSW", "VIC", "QLD"]}},
    {"filter": "datum.year >= '2015-16'"},
    {"calculate": "'20' + split(datum.year, '-')[1]", "as": "year_display"}
  ],
  "facet": {
    "field": "state",
    "type": "ordinal",
    "columns": 3,
    "title": null,
    "sort": ["NSW", "VIC", "QLD"],
    "header": {"labelFontSize": 13, "labelFontWeight": "bold", "labelColor": "#5dade2"}
  },
  "spec": {
    "width": 320,
    "layer": [
      {
        "mark": {
          "type": "area",
          "interpolate": "monotone",
          "line": true,
          "point": true,
          "color": "#5dade2",
          "strokeWidth": 2,
          "fillOpacity": 0.25
        },
        "encoding": {
          "x": {
            "field": "year",
            "type": "ordinal",
            "title": "Financial year",
            "sort": null,
            "axis": {
              "labelAngle": 0,
              "labelFontSize": 9,
              "labelExpr": "'20' + split(datum.label, '-')[1]"
            }
          },
          "y": {
            "field": "departures",
            "type": "quantitative",
            "title": "Departures",
            "axis": {"format": ",.0f"},
            "scale": {"domain": [0, 120000]}
          },
          "tooltip": [
            {"field": "state", "title": "State"},
            {"field": "year_display", "title": "Year"},
            {"field": "departures", "title": "Departures", "format": ","}
          ]
        }
      },
      {
        "mark": {"type": "rule", "color": "#e74c3c", "strokeDash": [4, 4], "strokeWidth": 1.5},
        "encoding": {"x": {"datum": "2020-21"}}
      },
      {
        "mark": {"type": "text", "align": "left", "dx": 4, "dy": -6, "fontSize": 9, "color": "#e74c3c"},
        "encoding": {
          "x": {"datum": "2020-21"},
          "y": {"value": 0},
          "text": {"value": "COVID-19"}
        }
      }
    ]
  },
  "resolve": {"scale": {"y": "shared"}},
  "config": {
    "background": "transparent",
    "view": {"stroke": null},
    "font": "DM Sans",
    "axis": {
      "labelFontSize": 11,
      "titleFontSize": 12,
      "labelColor": "#8aa4c0",
      "titleColor": "#e2eaf4",
      "gridColor": "rgba(255,255,255,0.08)",
      "domainColor": "rgba(255,255,255,0.15)",
      "tickColor": "rgba(255,255,255,0.15)"
    },
    "legend": {
      "labelColor": "#e2eaf4",
      "titleColor": "#e2eaf4"
    },
    "title": {
      "color": "#e2eaf4",
      "subtitleColor": "#8aa4c0"
    }
  }
}