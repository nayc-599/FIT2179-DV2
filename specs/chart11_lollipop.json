{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "COVID-19 recovery: 2025 vs 2019 departures",
    "subtitle": "Positive = exceeded pre-COVID levels. Negative = still below pre-COVID levels.",
    "font": "DM Sans",
    "subtitleFontSize": 12,
    "subtitleColor": "#b8d0e8"
  },
  "width": 950,
  "height": 360,
  "data": {"url": "data/chart11_dot_plot.csv"},
  "transform": [
    {"calculate": "datum.post_covid - datum.pre_covid", "as": "gap"},
    {"calculate": "datum.gap >= 0 ? 'Exceeded pre-COVID' : 'Below pre-COVID'", "as": "status"}
  ],
  "layer": [
    {
      "mark": {"type": "rule", "color": "rgba(255,255,255,0.2)", "strokeWidth": 1, "strokeDash": [4, 3]},
      "encoding": {"x": {"datum": 0}}
    },
    {
      "mark": {"type": "bar", "height": 6},
      "encoding": {
        "y": {
          "field": "display_country",
          "type": "nominal",
          "sort": {"field": "gap", "order": "descending"},
          "title": null,
          "axis": {"labelLimit": 120}
        },
        "x": {
          "field": "gap",
          "type": "quantitative",
          "title": "Change in annual departures (2025 minus 2019)",
          "axis": {"format": ",.0f"}
        },
        "color": {
          "field": "status",
          "type": "nominal",
          "scale": {
            "domain": ["Exceeded pre-COVID", "Below pre-COVID"],
            "range": ["#2e86de", "#c0392b"]
          },
          "legend": {"orient": "bottom", "title": null}
        }
      }
    },
    {
      "mark": {"type": "point", "filled": true, "size": 250},
      "encoding": {
        "y": {
          "field": "display_country",
          "type": "nominal",
          "sort": {"field": "gap", "order": "descending"},
          "title": null
        },
        "x": {"field": "gap", "type": "quantitative"},
        "color": {
          "field": "status",
          "type": "nominal",
          "scale": {
            "domain": ["Exceeded pre-COVID", "Below pre-COVID"],
            "range": ["#2e86de", "#c0392b"]
          },
          "legend": null
        },
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "pre_covid", "title": "2019", "format": ","},
          {"field": "post_covid", "title": "2025", "format": ","},
          {"field": "gap", "title": "Change", "format": "+,"}
        ]
      }
    },
    {
      "data": {"values": [{}]},
      "layer": [
        {
          "mark": {
            "type": "rect",
            "x": 800, "y": 120,
            "x2": 970, "y2": 220,
            "fill": "rgba(93,173,226,0.15)",
            "stroke": "#5dade2",
            "strokeWidth": 1.5,
            "cornerRadius": 6,
            "opacity": 0.95
          }
        },
        {
          "mark": {"type": "text", "x": 885, "y": 145, "fontSize": 14, "fontWeight": "bold", "color": "#5dade2", "text": "3 countries recovered"}
        },
        {
          "mark": {"type": "text", "x": 885, "y": 165, "fontSize": 12, "color": "#f0f6ff", "text": "India, Philippines & Japan"}
        },
        {
          "mark": {"type": "text", "x": 885, "y": 182, "fontSize": 12, "color": "#f0f6ff", "text": "exceeded pre-COVID levels"}
        }
      ]
    },
    {
      "data": {"values": [{}]},
      "layer": [
        {
          "mark": {
            "type": "rect",
            "x": 50, "y": 155,
            "x2": 260, "y2": 255,
            "fill": "rgba(230,57,70,0.12)",
            "stroke": "#E63946",
            "strokeWidth": 1.5,
            "cornerRadius": 6,
            "opacity": 0.95
          }
        },
        {
          "mark": {"type": "text", "x": 155, "y": 178, "fontSize": 14, "fontWeight": "bold", "color": "#E63946", "text": "China: largest gap"}
        },
        {
          "mark": {"type": "text", "x": 155, "y": 198, "fontSize": 12, "color": "#f0f6ff", "text": "Still 17,940 departures below"}
        },
        {
          "mark": {"type": "text", "x": 155, "y": 215, "fontSize": 12, "color": "#f0f6ff", "text": "its 2019 peak"}
        }
      ]
    },
    {
      "data": {"values": [{}]},
      "layer": [
        {
          "mark": {
            "type": "rect",
            "x": 450, "y": 35,
            "x2": 690, "y2": 130,
            "fill": "rgba(160,82,45,0.12)",
            "stroke": "#a0522d",
            "strokeWidth": 1.5,
            "cornerRadius": 6,
            "opacity": 0.95
          }
        },
        {
          "mark": {"type": "text", "x": 570, "y": 58, "fontSize": 14, "fontWeight": "bold", "color": "#a0522d", "text": "Indonesia: almost recovered"}
        },
        {
          "mark": {"type": "text", "x": 570, "y": 78, "fontSize": 12, "color": "#f0f6ff", "text": "Just 20 departures below"}
        },
        {
          "mark": {"type": "text", "x": 570, "y": 95, "fontSize": 12, "color": "#f0f6ff", "text": "its 2019 level"}
        }
      ]
    }
  ],
  "config": {
    "background": "transparent",
    "view": {"stroke": null},
    "font": "DM Sans",
    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 13,
      "labelColor": "#b8d0e8",
      "titleColor": "#f0f6ff",
      "gridColor": "rgba(255,255,255,0.08)",
      "domainColor": "rgba(255,255,255,0.15)",
      "tickColor": "rgba(255,255,255,0.15)"
    },
    "legend": {
      "labelColor": "#f0f6ff",
      "titleColor": "#f0f6ff",
      "labelFontSize": 13,
      "titleFontSize": 14
    },
    "title": {
      "color": "#f0f6ff",
      "subtitleColor": "#b8d0e8",
      "fontSize": 15,
      "subtitleFontSize": 13
    }
  }
}