{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "COVID-19 recovery: 2024–25 vs 2018–19 departures",
    "subtitle": "Positive = exceeded pre-COVID levels. Negative = still below pre-COVID levels.",
    "font": "DM Sans",
    "subtitleFontSize": 12,
    "subtitleColor": "#555"
  },
  "width": 950,
  "height": 360,
  "data": {"url": "data/chart11_dot_plot.csv"},
  "transform": [
    {"calculate": "datum.post_covid - datum.pre_covid", "as": "gap"},
    {"calculate": "datum.gap >= 0 ? 'Exceeded pre-COVID' : 'Below pre-COVID'", "as": "status"}
  ],
  "layer": [
    {
      "mark": {"type": "rule", "color": "#aaa", "strokeWidth": 1, "strokeDash": [4, 3]},
      "encoding": {"x": {"datum": 0}}
    },
    {
      "mark": {"type": "bar", "height": 6},
      "encoding": {
        "y": {
          "field": "display_country",
          "type": "nominal",
          "sort": {"field": "gap", "order": "descending"},
          "title": null,
          "axis": {"labelLimit": 120}
        },
        "x": {
          "field": "gap",
          "type": "quantitative",
          "title": "Change in annual departures (2024–25 minus 2018–19)",
          "axis": {"format": ",.0f"}
        },
        "color": {
          "field": "status",
          "type": "nominal",
          "scale": {
            "domain": ["Exceeded pre-COVID", "Below pre-COVID"],
            "range": ["#1D3557", "#c0392b"]
          },
          "legend": {"orient": "bottom", "title": null}
        }
      }
    },
    {
      "mark": {"type": "point", "filled": true, "size": 80},
      "encoding": {
        "y": {
          "field": "display_country",
          "type": "nominal",
          "sort": {"field": "gap", "order": "descending"},
          "title": null
        },
        "x": {"field": "gap", "type": "quantitative"},
        "color": {
          "field": "status",
          "type": "nominal",
          "scale": {
            "domain": ["Exceeded pre-COVID", "Below pre-COVID"],
            "range": ["#1D3557", "#c0392b"]
          },
          "legend": null
        },
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "pre_covid", "title": "2018–19", "format": ","},
          {"field": "post_covid", "title": "2024–25", "format": ","},
          {"field": "gap", "title": "Change", "format": "+,"}
        ]
      }
    },
    {
      "data": {"values": [{}]},
      "layer": [
        {
          "mark": {
            "type": "rect",
            "x": 800, "y": 120,
            "x2": 970, "y2": 205,
            "fill": "#eaf0fb",
            "stroke": "#1D3557",
            "strokeWidth": 1.5,
            "cornerRadius": 6,
            "opacity": 0.95
          }
        },
        {
          "mark": {"type": "text", "x": 885, "y": 145, "fontSize": 12, "fontWeight": "bold", "color": "#1D3557", "text": "3 countries recovered"}
        },
        {
          "mark": {"type": "text", "x": 885, "y": 165, "fontSize": 10, "color": "#333", "text": "India, Philippines & Japan"}
        },
        {
          "mark": {"type": "text", "x": 885, "y": 182, "fontSize": 10, "color": "#333", "text": "exceeded pre-COVID levels"}
        }
      ]
    },
    {
      "data": {"values": [{}]},
      "layer": [
        {
          "mark": {
            "type": "rect",
            "x": 50, "y": 155,
            "x2": 260, "y2": 240,
            "fill": "#fdedec",
            "stroke": "#c0392b",
            "strokeWidth": 1.5,
            "cornerRadius": 6,
            "opacity": 0.95
          }
        },
        {
          "mark": {"type": "text", "x": 155, "y": 178, "fontSize": 12, "fontWeight": "bold", "color": "#c0392b", "text": "China: largest gap"}
        },
        {
          "mark": {"type": "text", "x": 155, "y": 198, "fontSize": 10, "color": "#333", "text": "Still 17,940 departures below"}
        },
        {
          "mark": {"type": "text", "x": 155, "y": 215, "fontSize": 10, "color": "#333", "text": "its 2018–19 peak"}
        }
      ]
    },
    {
      "data": {"values": [{}]},
      "layer": [
        {
          "mark": {
            "type": "rect",
            "x": 450, "y": 35,
            "x2": 690, "y2": 115,
            "fill": "#fef9e7",
            "stroke": "#d4ac0d",
            "strokeWidth": 1.5,
            "cornerRadius": 6,
            "opacity": 0.95
          }
        },
        {
          "mark": {"type": "text", "x": 570, "y": 58, "fontSize": 12, "fontWeight": "bold", "color": "#d4ac0d", "text": "Indonesia: almost recovered"}
        },
        {
          "mark": {"type": "text", "x": 570, "y": 78, "fontSize": 10, "color": "#333", "text": "Just 20 departures below"}
        },
        {
          "mark": {"type": "text", "x": 570, "y": 95, "fontSize": 10, "color": "#333", "text": "its 2018–19 level"}
        }
      ]
    }
  ],
  "config": {
    "background": "transparent",
    "view": {"stroke": null},
    "font": "DM Sans",
    "axis": {"labelFontSize": 11, "titleFontSize": 12}
  }
}