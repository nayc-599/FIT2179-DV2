{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Migration departures and remittances, 2005 to 2025",
    "subtitle": "Overseas-born departures (left) and personal remittances received by Australia in AUD dollars (right)",
    "font": "DM Sans",
    "subtitleFontSize": 12,
    "subtitleColor": "#b8d0e8"
  },
  "width": 920,
  "height": 380,
  "data": {"url": "data/chart1_totals.csv"},
  "transform": [
    {"calculate": "'20' + split(datum.year, '-')[1]", "as": "year_label"}
  ],
  "layer": [
    {
      "mark": {"type": "line", "point": true, "strokeWidth": 2.5},
      "encoding": {
        "x": {
          "field": "year", "type": "ordinal", "title": "Financial year", "sort": null,
          "axis": {"labelAngle": 0, "labelExpr": "'20' + split(datum.label, '-')[1]"}
        },
        "y": {
          "field": "departures", "type": "quantitative",
          "title": "Total departures (overseas-born)",
          "axis": {"format": ",.0f", "titleColor": "#5dade2"},
          "scale": {"zero": false}
        },
        "color": {"value": "#5dade2"},
        "tooltip": [
          {"field": "year_label", "title": "Year"},
          {"field": "departures", "title": "Departures", "format": ","}
        ]
      }
    },
    {
      "mark": {"type": "line", "point": true, "strokeWidth": 2.5},
      "encoding": {
        "x": {"field": "year", "type": "ordinal", "sort": null},
        "y": {
          "field": "remittances_aud", "type": "quantitative",
          "title": "Remittances received (A$)",
          "axis": {"format": "~s", "titleColor": "#e74c3c"},
          "scale": {"zero": false}
        },
        "color": {"value": "#e74c3c"},
        "tooltip": [
          {"field": "year_label", "title": "Year"},
          {"field": "remittances_aud", "title": "Remittances (A$)", "format": "~s"}
        ]
      }
    },
    {
      "mark": {"type": "rule", "color": "#e74c3c", "strokeWidth": 2, "strokeDash": [6, 4]},
      "encoding": {"x": {"datum": "2020-21"}}
    },
    {
      "mark": {"type": "text", "align": "left", "dx": 6, "dy": -8, "fontSize": 11, "fontWeight": "bold", "color": "#e74c3c"},
      "encoding": {
        "x": {"datum": "2020-21"},
        "y": {"value": 0},
        "text": {"value": "COVID-19"}
      }
    },
    {
      "data": {"values": [{}]},
      "layer": [
        {"mark": {"type": "rect", "x": 20, "y": 20, "x2": 280, "y2": 120, "fill": "rgba(231,76,60,0.15)", "stroke": "#e74c3c", "strokeWidth": 1.5, "cornerRadius": 6, "opacity": 0.95}},
        {"mark": {"type": "text", "x": 150, "y": 45, "fontSize": 14, "fontWeight": "bold", "color": "#e74c3c", "text": "Remittances peaked 2012–14"}},
        {"mark": {"type": "text", "x": 150, "y": 65, "fontSize": 12, "color": "#f0f6ff", "text": "driven by strong commodity prices"}},
        {"mark": {"type": "text", "x": 150, "y": 83, "fontSize": 12, "color": "#f0f6ff", "text": "and a high AUD exchange rate"}},

        {"mark": {"type": "rect", "x": 740, "y": 45, "x2": 900, "y2": 160, "fill": "rgba(93,173,226,0.15)", "stroke": "#5dade2", "strokeWidth": 1.5, "cornerRadius": 6, "opacity": 0.95}},
        {"mark": {"type": "text", "x": 820, "y": 68, "fontSize": 14, "fontWeight": "bold", "color": "#5dade2", "text": "Remittances resilient"}},
        {"mark": {"type": "text", "x": 820, "y": 88, "fontSize": 12, "color": "#f0f6ff", "text": "Departures fell sharply"}},
        {"mark": {"type": "text", "x": 820, "y": 104, "fontSize": 12, "color": "#f0f6ff", "text": "in 2022 but remittances"}},
        {"mark": {"type": "text", "x": 820, "y": 120, "fontSize": 12, "color": "#f0f6ff", "text": "recovered faster"}},
        {"mark": {"type": "text", "x": 820, "y": 138, "fontSize": 11, "color": "#b8d0e8", "fontStyle": "italic", "text": "money outlasts movement"}},

        {"mark": {"type": "rect", "x": 430, "y": 235, "x2": 670, "y2": 325, "fill": "rgba(93,173,226,0.15)", "stroke": "#5dade2", "strokeWidth": 1.5, "cornerRadius": 6, "opacity": 0.95}},
        {"mark": {"type": "text", "x": 550, "y": 258, "fontSize": 14, "fontWeight": "bold", "color": "#5dade2", "text": "Departures plateaued"}},
        {"mark": {"type": "text", "x": 550, "y": 278, "fontSize": 12, "color": "#f0f6ff", "text": "2013–17 saw steady but slow"}},
        {"mark": {"type": "text", "x": 550, "y": 295, "fontSize": 12, "color": "#f0f6ff", "text": "growth before the 2020 surge"}}
      ]
    }
  ],
  "resolve": {"scale": {"y": "independent"}},
  "config": {
    "background": "transparent",
    "view": {"stroke": null},
    "font": "DM Sans",
    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 13,
      "labelColor": "#b8d0e8",
      "titleColor": "#f0f6ff",
      "gridColor": "rgba(255,255,255,0.08)",
      "domainColor": "rgba(255,255,255,0.15)",
      "tickColor": "rgba(255,255,255,0.15)"
    },
    "legend": {"labelColor": "#f0f6ff", "titleColor": "#f0f6ff", "labelFontSize": 13, "titleFontSize": 14},
    "title": {"color": "#f0f6ff", "subtitleColor": "#b8d0e8", "fontSize": 15, "subtitleFontSize": 13}
  }
}