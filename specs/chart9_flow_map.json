{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Where do Australia's emigrants come from?",
    "subtitle": "Shading shows total departures 2004\u201325. Line width = departure volume. Hover to highlight.",
    "font": "DM Sans",
    "subtitleFontSize": 12,
    "subtitleColor": "#8aa4c0"
  },
  "width": 900,
  "height": 450,
  "projection": {"type": "naturalEarth1"},
  "params": [
    {"name": "continent_select", "value": null}
  ],
  "layer": [
    {
      "data": {
        "url": "data/world-countries-110m.json",
        "format": {"type": "topojson", "feature": "countries"}
      },
      "mark": {"type": "geoshape", "fill": "#d0d8e0", "stroke": "#aab4be", "strokeWidth": 0.3},
      "encoding": {"tooltip": null}
    },
    {
      "data": {
        "url": "data/world-countries-110m.json",
        "format": {"type": "topojson", "feature": "countries"}
      },
      "transform": [
        {
          "lookup": "id",
          "from": {
            "data": {"url": "data/chart9_top10_highlight.csv"},
            "key": "numeric_id",
            "fields": ["display_country", "continent", "departures"]
          }
        },
        {"filter": "isValid(datum.departures)"}
      ],
      "mark": {"type": "geoshape", "stroke": "#fff", "strokeWidth": 0.8},
      "encoding": {
        "color": {
          "field": "departures",
          "type": "quantitative",
          "scale": {
            "type": "log",
            "scheme": "yellowgreen",
            "domainMin": 70000
          },
          "legend": {
            "title": "Total departures",
            "format": ",.0f",
            "titleFontSize": 11,
            "labelFontSize": 10
          }
        },
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "departures", "title": "Total departures", "format": ","}
        ]
      }
    },
    {
      "data": {"url": "data/chart9_flow.csv"},
      "params": [
        {
          "name": "chart9_flowHoverUnique",
          "select": {
            "type": "point",
            "fields": ["display_country"],
            "on": "mouseover",
            "clear": "mouseout"
          }
        }
      ],
      "mark": {
        "type": "line",
        "interpolate": "cardinal",
        "tension": 0.5,
        "strokeLinecap": "round",
        "strokeLinejoin": "round"
      },
      "encoding": {
        "latitude": {"field": "plot_lat"},
        "longitude": {"field": "plot_lon"},
        "detail": {"field": "display_country"},
        "order": {"field": "point_order", "type": "quantitative"},
        "strokeWidth": {
          "field": "departures",
          "type": "quantitative",
          "scale": {"range": [2, 18]},
          "legend": null
        },
        "color": {
          "field": "continent",
          "type": "nominal",
          "legend": {"orient": "bottom", "title": "Continent"},
          "scale": {
            "domain": ["Asia", "Europe", "Oceania", "Americas", "Africa", "Middle East"],
            "range": ["#E91E8C", "#54a0ff", "#16a085", "#7d3c98", "#d35400", "#d4ac0d"]
          }
        },
        "opacity": {
          "condition": {
            "test": "continent_select === null || datum.continent === continent_select",
            "value": 1
          },
          "value": 0.15
        },
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "departures", "title": "Total departures", "format": ","},
          {"field": "continent", "title": "Continent"}
        ]
      }
    },
    {
      "data": {"url": "data/chart9_flow.csv"},
      "transform": [{"filter": "datum.point_order === 1"}],
      "mark": {
        "type": "circle",
        "filled": true,
        "size": 60,
        "stroke": "#fff",
        "strokeWidth": 1.5
      },
      "encoding": {
        "latitude": {"field": "plot_lat"},
        "longitude": {"field": "plot_lon"},
        "color": {
          "field": "continent",
          "type": "nominal",
          "legend": null,
          "scale": {
            "domain": ["Asia", "Europe", "Oceania", "Americas", "Africa", "Middle East"],
            "range": ["#E91E8C", "#54a0ff", "#16a085", "#7d3c98", "#d35400", "#d4ac0d"]
          }
        },
        "opacity": {
          "condition": [
            {"param": "chart9_flowHoverUnique", "empty": false, "value": 1},
            {"param": "chart9_flowHoverUnique", "empty": true, "value": 0.8}
          ],
          "value": 0.8
        },
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "departures", "title": "Total departures", "format": ","},
          {"field": "continent", "title": "Continent"}
        ]
      }
    },
    {
      "data": {"url": "data/chart9_flow.csv"},
      "transform": [{"filter": "datum.point_order === 1"}],
      "mark": {
        "type": "point",
        "shape": "triangle",
        "filled": true,
        "size": 150
      },
      "encoding": {
        "latitude": {"field": "plot_lat"},
        "longitude": {"field": "plot_lon"},
        "angle": {"field": "angle", "type": "quantitative"},
        "color": {
          "field": "continent",
          "type": "nominal",
          "legend": null,
          "scale": {
            "domain": ["Asia", "Europe", "Oceania", "Americas", "Africa", "Middle East"],
            "range": ["#E91E8C", "#54a0ff", "#16a085", "#7d3c98", "#d35400", "#d4ac0d"]
          }
        },
        "opacity": {"value": 1},
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "departures", "title": "Total departures", "format": ","},
          {"field": "continent", "title": "Continent"}
        ]
      }
    },
    {
      "data": {"values": [{}]},
      "layer": [
        {
          "mark": {
            "type": "rect",
            "x": 20, "y": 280, "x2": 260, "y2": 355,
            "fill": "rgba(93,173,226,0.15)",
            "stroke": "#2e86de",
            "strokeWidth": 1.5,
            "cornerRadius": 6,
            "opacity": 0.95
          }
        },
        {
          "mark": {"type": "text", "x": 140, "y": 300, "fontSize": 12, "fontWeight": "bold", "color": "#2e86de", "text": "3.9M total departures"}
        },
        {
          "mark": {"type": "text", "x": 140, "y": 320, "fontSize": 10, "color": "#e2eaf4", "text": "from 10 countries over 21 years"}
        },
        {
          "mark": {"type": "text", "x": 140, "y": 335, "fontSize": 10, "color": "#e2eaf4", "text": "Darker shading = more emigrants"}
        }
      ]
    }
  ],
  "config": {
    "background": "transparent",
    "view": {"stroke": null},
    "font": "DM Sans",
    "axis": {
      "labelFontSize": 11,
      "titleFontSize": 12,
      "labelColor": "#8aa4c0",
      "titleColor": "#e2eaf4",
      "gridColor": "rgba(255,255,255,0.08)",
      "domainColor": "rgba(255,255,255,0.15)",
      "tickColor": "rgba(255,255,255,0.15)"
    },
    "legend": {
      "labelColor": "#e2eaf4",
      "titleColor": "#e2eaf4"
    },
    "title": {
      "color": "#e2eaf4",
      "subtitleColor": "#8aa4c0"
    }
  }
}