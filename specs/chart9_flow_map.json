{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Flows from top countries of birth to Australia",
    "subtitle": "Line width = total departures (2004–05 to 2024–25). Colour = continent.",
    "font": "DM Sans",
    "subtitleFontSize": 12,
    "subtitleColor": "#555"
  },
  "width": 900,
  "height": 500,
  "projection": {"type": "naturalEarth1"},
  "layer": [
    {
      "data": {
        "url": "data/world-countries-110m.json",
        "format": {"type": "topojson", "feature": "countries"}
      },
      "mark": {"type": "geoshape", "fill": "#b8c4d0", "stroke": "#8a9bb0", "strokeWidth": 0.3},
      "encoding": {"tooltip": null}
    },
    {
      "data": {"url": "data/chart9_flow.csv"},
      "params": [
        {
          "name": "chart9_flowHoverUnique",
          "select": {
            "type": "point",
            "fields": ["display_country"],
            "on": "mouseover",
            "clear": "mouseout"
          }
        }
      ],
      "mark": {
        "type": "line",
        "interpolate": "cardinal",
        "tension": 0.5,
        "strokeLinecap": "round",
        "strokeLinejoin": "round"
      },
      "encoding": {
        "latitude": {"field": "plot_lat"},
        "longitude": {"field": "plot_lon"},
        "detail": {"field": "display_country"},
        "order": {"field": "point_order", "type": "quantitative"},
        "strokeWidth": {
          "field": "departures",
          "type": "quantitative",
          "scale": {"range": [1, 12]},
          "legend": {"title": "Departures", "format": ",.0f"}
        },
        "color": {
          "field": "continent",
          "type": "nominal",
          "legend": {"orient": "bottom", "title": "Continent"},
          "scale": {
            "domain": ["Asia", "Europe", "Oceania", "Americas", "Africa", "Middle East"],
            "range": ["#1a5276", "#2980b9", "#16a085", "#8e44ad", "#d35400", "#c0392b"]
          }
        },
        "opacity": {
          "condition": [
            {"param": "chart9_flowHoverUnique", "empty": false, "value": 1},
            {"param": "chart9_flowHoverUnique", "empty": true, "value": 0.45}
          ],
          "value": 0.15
        },
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "departures", "title": "Total departures", "format": ","},
          {"field": "continent", "title": "Continent"}
        ]
      }
    },
    {
      "data": {"url": "data/chart9_flow.csv"},
      "transform": [{"filter": "datum.point_order === 3"}],
      "mark": {
        "type": "point",
        "shape": "triangle",
        "filled": true,
        "size": 80
      },
      "encoding": {
        "latitude": {"field": "plot_lat"},
        "longitude": {"field": "plot_lon"},
        "angle": {"field": "angle", "type": "quantitative"},
        "color": {
          "field": "continent",
          "type": "nominal",
          "legend": null,
          "scale": {
            "domain": ["Asia", "Europe", "Oceania", "Americas", "Africa", "Middle East"],
            "range": ["#1a5276", "#2980b9", "#16a085", "#8e44ad", "#d35400", "#c0392b"]
          }
        },
        "opacity": {
          "condition": [
            {"param": "chart9_flowHoverUnique", "empty": false, "value": 1},
            {"param": "chart9_flowHoverUnique", "empty": true, "value": 0.45}
          ],
          "value": 0.15
        },
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "departures", "title": "Total departures", "format": ","},
          {"field": "continent", "title": "Continent"}
        ]
      }
    },
    {
      "data": {"url": "data/chart9_flow.csv"},
      "transform": [{"filter": "datum.point_order === 1"}],
      "mark": {"type": "circle", "filled": true, "size": 80},
      "encoding": {
        "latitude": {"field": "plot_lat"},
        "longitude": {"field": "plot_lon"},
        "color": {
          "field": "continent",
          "type": "nominal",
          "legend": null,
          "scale": {
            "domain": ["Asia", "Europe", "Oceania", "Americas", "Africa", "Middle East"],
            "range": ["#1a5276", "#2980b9", "#16a085", "#8e44ad", "#d35400", "#c0392b"]
          }
        },
        "opacity": {
          "condition": [
            {"param": "chart9_flowHoverUnique", "empty": false, "value": 1},
            {"param": "chart9_flowHoverUnique", "empty": true, "value": 0.45}
          ],
          "value": 0.15
        },
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "departures", "title": "Total departures", "format": ","},
          {"field": "continent", "title": "Continent"}
        ]
      }
    },
    {
      "data": {"values": [{"lat": -25.0, "lon": 133.0, "label": "Australia"}]},
      "mark": {"type": "circle", "filled": true, "color": "#1a5276", "size": 120},
      "encoding": {
        "latitude": {"field": "lat"},
        "longitude": {"field": "lon"},
        "tooltip": [{"field": "label", "title": "Destination"}]
      }
    }
  ],
  "config": {"background": "transparent","view": {"stroke": null}, "font": "DM Sans"}
}
