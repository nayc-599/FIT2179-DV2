{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Flows from top countries of birth to Australia",
    "subtitle": "Line width = total departures (2004–05 to 2024–25). Colour = continent.",
    "font": "DM Sans",
    "subtitleFontSize": 12,
    "subtitleColor": "#555"
  },
  "width": 700,
  "height": 400,
  "projection": {"type": "naturalEarth1"},
  "params": [
    {
      "name": "chart9_flowHighlight",
      "select": {
        "type": "point",
        "fields": ["display_country"],
        "on": "mouseover",
        "clear": "mouseout"
      }
    }
  ],
  "layer": [
    {
      "data": {
        "url": "data/world-countries-110m.json",
        "format": {"type": "topojson", "feature": "countries"}
      },
      "mark": {"type": "geoshape", "fill": "#e8ecef", "stroke": "#ccc", "strokeWidth": 0.3},
      "encoding": {
        "tooltip": null
      }
    },
    {
      "data": {"url": "data/chart9_flow.csv"},
      "mark": {"type": "rule", "strokeCap": "round"},
      "encoding": {
        "latitude": {"field": "lat"},
        "longitude": {"field": "lon"},
        "latitude2": {"field": "dest_lat"},
        "longitude2": {"field": "dest_lon"},
        "strokeWidth": {
          "field": "departures",
          "type": "quantitative",
          "scale": {"range": [1, 12]},
          "legend": {"title": "Departures", "format": ",.0f"}
        },
        "color": {
          "field": "continent",
          "type": "nominal",
          "legend": {"orient": "bottom", "title": "Continent"},
          "scale": {
            "domain": ["Asia", "Europe", "Oceania", "Americas", "Africa", "Middle East"],
            "range": ["#1a5276", "#2980b9", "#16a085", "#8e44ad", "#d35400", "#c0392b"]
          }
        },
        "opacity": {
          "condition": [
            {"param": "chart9_flowHighlight", "value": 1},
            {"test": "chart9_flowHighlight", "value": 0.15}
          ],
          "value": 0.45
        },
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "departures", "title": "Total departures", "format": ","},
          {"field": "continent", "title": "Continent"}
        ]
      }
    },
    {
      "data": {"url": "data/chart9_flow.csv"},
      "mark": {"type": "circle", "filled": true, "size": 80},
      "encoding": {
        "latitude": {"field": "lat"},
        "longitude": {"field": "lon"},
        "color": {
          "field": "continent",
          "type": "nominal",
          "legend": null,
          "scale": {
            "domain": ["Asia", "Europe", "Oceania", "Americas", "Africa", "Middle East"],
            "range": ["#1a5276", "#2980b9", "#16a085", "#8e44ad", "#d35400", "#c0392b"]
          }
        },
        "opacity": {
          "condition": [
            {"param": "chart9_flowHighlight", "value": 1},
            {"test": "chart9_flowHighlight", "value": 0.15}
          ],
          "value": 0.45
        },
        "tooltip": [{"field": "display_country", "title": "Origin"}]
      }
    },
    {
      "data": {"values": [{"lat": -35.2809, "lon": 149.13, "label": "Australia"}]},
      "mark": {"type": "circle", "filled": true, "color": "#1a5276", "size": 120},
      "encoding": {
        "latitude": {"field": "lat"},
        "longitude": {"field": "lon"},
        "tooltip": [{"field": "label", "title": "Destination"}]
      }
    }
  ],
  "config": {"view": {"stroke": null}, "font": "DM Sans"}
}
