{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Ranking of top departure countries, 2014–15 to 2024–25",
    "subtitle": "Rank 1 = most departures (top). Thick bands show how each country's rank shifted — hover to focus.",
    "font": "DM Sans",
    "subtitleFontSize": 12,
    "subtitleColor": "#555"
  },
  "width": "container",
  "height": 480,
  "data": {"url": "data/chart4_bump.csv"},
  "layer": [
    {
      "params": [
        {
          "name": "c4_hover",
          "select": {
            "type": "point",
            "fields": ["display_country"],
            "on": "mouseover",
            "clear": "mouseout"
          }
        }
      ],
      "mark": {
        "type": "line",
        "interpolate": "monotone",
        "strokeWidth": 36,
        "stroke": "transparent",
        "tooltip": null
      },
      "encoding": {
        "x": {"field": "year", "type": "ordinal", "sort": null},
        "y": {
          "field": "rank",
          "type": "quantitative",
          "scale": {"reverse": true, "domain": [0.5, 10.5], "nice": false}
        },
        "detail": {"field": "display_country"},
        "color": {"value": "transparent"}
      }
    },
    {
      "mark": {
        "type": "line",
        "interpolate": "monotone",
        "strokeWidth": 22,
        "strokeLinecap": "round",
        "strokeLinejoin": "round"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": "Financial year",
          "sort": null,
          "axis": {"labelAngle": -45}
        },
        "y": {
          "field": "rank",
          "type": "quantitative",
          "title": "Rank",
          "scale": {"reverse": true, "domain": [0.5, 10.5], "nice": false},
          "axis": {"tickMinStep": 1, "format": "d"}
        },
        "color": {
          "field": "display_country",
          "type": "nominal",
          "legend": {"orient": "right", "columns": 1, "title": "Country"},
          "scale": {
            "scheme": "tableau10",
            "domain": ["China","UK","New Zealand","India","USA","Korea South","Malaysia","Japan","Indonesia","Philippines"]
          }
        },
        "opacity": {
          "condition": {"param": "c4_hover", "empty": false, "value": 1},
          "value": 0.7
        },
        "detail": {"field": "display_country"},
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "year", "title": "Year"},
          {"field": "rank", "title": "Rank"},
          {"field": "departures", "title": "Departures", "format": ","}
        ]
      }
    },
    {
      "transform": [{"filter": {"field": "year", "equal": "2024-25"}}],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 10,
        "fontSize": 11,
        "fontWeight": 600,
        "baseline": "middle"
      },
      "encoding": {
        "x": {"field": "year", "type": "ordinal", "sort": null},
        "y": {
          "field": "rank",
          "type": "quantitative",
          "scale": {"reverse": true, "domain": [0.5, 10.5], "nice": false}
        },
        "text": {"field": "display_country"},
        "color": {
          "field": "display_country",
          "type": "nominal",
          "scale": {
            "scheme": "tableau10",
            "domain": ["China","UK","New Zealand","India","USA","Korea South","Malaysia","Japan","Indonesia","Phillips"]
          }
        },
        "opacity": {
          "condition": {"param": "c4_hover", "empty": false, "value": 1},
          "value": 0.9
        }
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "font": "DM Sans",
    "axis": {"labelFontSize": 11, "titleFontSize": 12}
  }
}
