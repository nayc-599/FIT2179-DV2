{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Ranking of top departure countries, 2014–15 to 2024–25",
    "subtitle": "Rank 1 = most departures (top). Use the slider or press Play to animate.",
    "font": "DM Sans",
    "subtitleFontSize": 12,
    "subtitleColor": "#555"
  },
  "width": 900,
  "height": 480,
  "data": {"url": "data/chart4_bump.csv"},
  "params": [
    {
      "name": "max_year_index",
      "value": 12,
      "bind": {
        "input": "range",
        "min": 1,
        "max": 12,
        "step": 1,
        "name": "Years shown: "
      }
    }
  ],
  "transform": [
    {
      "calculate": "indexof(['2014-15','2015-16','2016-17','2017-18','2018-19','2019-20','2020-21','2021-22','2022-23','2023-24','2024-25','2024-26'], datum.year)",
      "as": "year_index"
    },
    {"filter": "datum.year_index < max_year_index"}
  ],
  "layer": [
    {
      "params": [
        {
          "name": "c4_hover",
          "select": {
            "type": "point",
            "fields": ["display_country"],
            "on": "mouseover",
            "clear": "mouseout"
          }
        }
      ],
      "mark": {
        "type": "line",
        "interpolate": "monotone",
        "strokeWidth": 36,
        "stroke": "transparent",
        "tooltip": null
      },
      "encoding": {
        "x": {"field": "year", "type": "ordinal", "sort": null},
        "y": {
          "field": "rank",
          "type": "quantitative",
          "scale": {"reverse": true, "domain": [0.5, 10.5], "nice": false}
        },
        "detail": {"field": "display_country"},
        "color": {"value": "transparent"}
      }
    },
    {
      "mark": {
        "type": "line",
        "interpolate": "monotone",
        "strokeWidth": 22,
        "strokeLinecap": "round",
        "strokeLinejoin": "round"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": "Financial year",
          "sort": null,
          "axis": {
            "labelAngle": 0,
            "labelAlign": "center",
            "labelExpr": "datum.label === '2024-26' ? '' : '20' + split(datum.label, '-')[1]"
          }
        },
        "y": {
          "field": "rank",
          "type": "quantitative",
          "title": "Rank",
          "scale": {"reverse": true, "domain": [0.5, 10.5], "nice": false},
          "axis": {"tickMinStep": 1, "format": "d"}
        },
        "color": {
          "field": "display_country",
          "type": "nominal",
          "legend": {"orient": "right", "columns": 1, "title": "Country"},
          "scale": {
            "domain": ["China","UK","New Zealand","India","USA","Korea South","Malaysia","Japan","Indonesia","Philippines"],
            "range": ["#E63946","#1D3557","#9B72CF","#F4A261","#7B2D8B","#F4D03F","#E76F51","#E8A0BF","#8B4513","#00B4D8"]
          }
        },
        "opacity": {
          "condition": {"param": "c4_hover", "empty": false, "value": 1},
          "value": 0.7
        },
        "detail": {"field": "display_country"},
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "year", "title": "Year"},
          {"field": "rank", "title": "Rank"},
          {"field": "departures", "title": "Departures", "format": ","}
        ]
      }
    },
    {
      "transform": [
        {"filter": "datum.year === '2024-26'"},
        {
          "calculate": "datum.display_country == 'China' ? 24 : datum.display_country == 'India' ? 72 : datum.display_country == 'UK' ? 120 : datum.display_country == 'New Zealand' ? 168 : datum.display_country == 'Japan' ? 216 : datum.display_country == 'Philippines' ? 264 : datum.display_country == 'Korea South' ? 312 : datum.display_country == 'Indonesia' ? 360 : datum.display_country == 'Malaysia' ? 408 : 456",
          "as": "flag_y"
        }
      ],
      "mark": {
        "type": "image",
        "width": 32,
        "height": 22,
        "align": "left",
        "baseline": "middle"
      },
      "encoding": {
        "x": {"value": 870},
        "y": {"field": "flag_y", "type": "quantitative", "scale": null},
        "url": {"field": "flag_url", "type": "nominal"},
        "opacity": {"value": 1},
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "rank", "title": "Rank"},
          {"field": "departures", "title": "Departures", "format": ","}
        ]
      }
    }
  ],
  "config": {
    "background": "transparent",
    "view": {"stroke": null},
    "font": "DM Sans",
    "axis": {"labelFontSize": 11, "titleFontSize": 12}
  }
}