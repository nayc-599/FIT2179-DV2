{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Departures from Australia over time \u2014 top 10 countries",
    "subtitle": "Stacked annual departures by country of birth. Hover to highlight.",
    "font": "DM Sans",
    "subtitleFontSize": 12,
    "subtitleColor": "#8aa4c0"
  },
  "width": 875,
  "height": 340,
  "data": {"url": "data/chart_departures_top10_time.csv"},
  "transform": [
    {
      "joinaggregate": [
        {"op": "sum", "field": "departures", "as": "total_departures"}
      ],
      "groupby": ["display_country"]
    },
    {"calculate": "'20' + split(datum.year, '-')[1]", "as": "year_display"}
  ],
  "layer": [
    {
      "params": [
        {
          "name": "dep_hover",
          "select": {
            "type": "point",
            "fields": ["display_country"],
            "on": "mouseover",
            "clear": "mouseout"
          }
        },
        {
          "name": "dep_filter",
          "select": {
            "type": "point",
            "fields": ["display_country"]
          },
          "bind": "legend"
        }
      ],
      "mark": {
        "type": "area",
        "interpolate": "monotone",
        "line": true,
        "opacity": 0.7
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": "Financial year",
          "sort": null,
          "axis": {
            "labelAngle": 0,
            "labelExpr": "'20' + split(datum.label, '-')[1]"
          }
        },
        "y": {
          "field": "departures",
          "type": "quantitative",
          "title": "Annual departures",
          "axis": {"format": ",.0f"},
          "stack": true
        },
        "order": {"field": "total_departures", "sort": "descending"},
        "color": {
          "field": "display_country",
          "type": "nominal",
          "title": "Country",
          "legend": {"orient": "right"},
          "scale": {
            "domain": ["Philippines","Indonesia","Japan","Malaysia","Korea South","USA","India","New Zealand","UK","China"],
            "range": ["#00B4D8","#8B4513","#E8A0BF","#E76F51","#F4D03F","#a855f7","#E07020","#9B72CF","#2e86de","#E63946"]
          }
        },
        "opacity": {
          "condition": [
            {"param": "dep_filter", "empty": true, "value": 0.8},
            {"param": "dep_filter", "empty": false, "value": 1}
          ],
          "value": 0.1
        },
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "year_display", "title": "Year"},
          {"field": "departures", "title": "Departures", "format": ","}
        ]
      }
    },
    {
      "data": {"values": [{}]},
      "layer": [
        {
          "mark": {
            "type": "rect",
            "x": 580, "y": 20, "x2": 790, "y2": 130,
            "fill": "rgba(231,76,60,0.15)",
            "stroke": "#e74c3c",
            "strokeWidth": 1.5,
            "cornerRadius": 6,
            "opacity": 0.95
          }
        },
        {
          "mark": {"type": "text", "x": 685, "y": 46, "fontSize": 12, "fontWeight": "bold", "color": "#e74c3c", "text": "COVID-19 peak then collapse"}
        },
        {
          "mark": {"type": "text", "x": 685, "y": 66, "fontSize": 10, "color": "#e2eaf4", "text": "2019\u201320 saw the highest departures"}
        },
        {
          "mark": {"type": "text", "x": 685, "y": 84, "fontSize": 10, "color": "#e2eaf4", "text": "before COVID-19 cut them by 46%"}
        },
        {
          "mark": {"type": "text", "x": 685, "y": 102, "fontSize": 10, "color": "#e2eaf4", "text": "in a single year \u2014 2020\u201321"}
        }
      ]
    }
  ],
  "config": {
    "background": "transparent",
    "view": {"stroke": null},
    "font": "DM Sans",
    "axis": {
      "labelFontSize": 11,
      "titleFontSize": 12,
      "labelColor": "#8aa4c0",
      "titleColor": "#e2eaf4",
      "gridColor": "rgba(255,255,255,0.08)",
      "domainColor": "rgba(255,255,255,0.15)",
      "tickColor": "rgba(255,255,255,0.15)"
    },
    "legend": {
      "labelColor": "#e2eaf4",
      "titleColor": "#e2eaf4"
    },
    "title": {
      "color": "#e2eaf4",
      "subtitleColor": "#8aa4c0"
    }
  }
}