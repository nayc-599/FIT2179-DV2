{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Remittances received over time \u2014 top emigrant-source countries",
    "subtitle": "Personal remittances received (current AUD). Hover to highlight a country. (2025 country-level data not yet available.)",
    "font": "DM Sans",
    "subtitleFontSize": 12,
    "subtitleColor": "#b8d0e8"
  },
  "width": 870,
  "height": 380,
  "data": {"url": "data/chart_remittances_top10.csv"},
  "config": {
    "background": "transparent",
    "view": {"stroke": null},
    "font": "DM Sans",
    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 13,
      "labelColor": "#b8d0e8",
      "titleColor": "#f0f6ff",
      "gridColor": "rgba(255,255,255,0.08)",
      "domainColor": "rgba(255,255,255,0.15)",
      "tickColor": "rgba(255,255,255,0.15)"
    },
    "legend": {
      "labelColor": "#f0f6ff",
      "titleColor": "#f0f6ff",
      "labelFontSize": 13,
      "titleFontSize": 14
    },
    "title": {
      "color": "#f0f6ff",
      "subtitleColor": "#b8d0e8",
      "fontSize": 15,
      "subtitleFontSize": 13
    }
  },
  "layer": [
    {
      "params": [
        {
          "name": "rem_hover",
          "select": {
            "type": "point",
            "fields": ["display_country"],
            "on": "mouseover",
            "clear": "mouseout"
          }
        },
        {
          "name": "rem_filter",
          "select": {
            "type": "point",
            "fields": ["display_country"]
          },
          "bind": "legend"
        }
      ],
      "transform": [
        {
          "joinaggregate": [
            {"op": "sum", "field": "remittances_usd", "as": "total_remittances"}
          ],
          "groupby": ["display_country"]
        }
      ],
      "mark": {
        "type": "area",
        "interpolate": "monotone",
        "line": true,
        "opacity": 0.7
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": "Year",
          "sort": null,
          "axis": {"labelAngle": 0}
        },
        "y": {
          "field": "remittances_usd",
          "type": "quantitative",
          "title": "Remittances received (A$)",
          "axis": {"format": "~s"},
          "stack": true
        },
        "order": {
          "field": "total_remittances",
          "sort": "descending"
        },
        "color": {
          "field": "display_country",
          "type": "nominal",
          "title": "Country",
          "legend": {"orient": "right"},
          "scale": {
            "domain": ["New Zealand","Malaysia","Japan","Korea South","UK","USA","Indonesia","China","Philippines","India"],
            "range": ["#b8860b","#c5b4e3","#ff6b9d","#F4D03F","#2e86de","#a855f7","#a0522d","#E63946","#00B4D8","#E07020"]
          }
        },
        "opacity": {
          "condition": [
            {"param": "rem_filter", "empty": true, "value": 0.8},
            {"param": "rem_filter", "empty": false, "value": 1}
          ],
          "value": 0.1
        },
        "strokeWidth": {
          "condition": [
            {"param": "rem_filter", "empty": true, "value": 1.5},
            {"param": "rem_filter", "empty": false, "value": 2.5}
          ],
          "value": 0.5
        },
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "year", "title": "Year"},
          {"field": "remittances_usd", "title": "Remittances (A$)", "format": "~s"}
        ]
      }
    },
    {
      "data": {"values": [{}]},
      "layer": [
        {
          "mark": {
            "type": "rect",
            "x": 20, "y": 15, "x2": 280, "y2": 110,
            "fill": "rgba(224,112,32,0.12)",
            "stroke": "#E07020",
            "strokeWidth": 1.5,
            "cornerRadius": 6,
            "opacity": 0.95
          }
        },
        {
          "mark": {"type": "text", "x": 150, "y": 40, "fontSize": 14, "fontWeight": "bold", "color": "#E07020", "text": "India towers above all"}
        },
        {
          "mark": {"type": "text", "x": 150, "y": 60, "fontSize": 12, "color": "#f0f6ff", "text": "$19B in 2004 -> $120B in 2023"}
        },
        {
          "mark": {"type": "text", "x": 150, "y": 78, "fontSize": 12, "color": "#f0f6ff", "text": "a 6× increase in 20 years"}
        }
      ]
    }
  ]
}