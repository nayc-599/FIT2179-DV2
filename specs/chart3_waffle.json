{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Share of departures by continent",
    "subtitle": "Each flag = 1% of total overseas-born departures (2004–05 to 2024–25). Flag = highest-departure country per continent.",
    "font": "DM Sans",
    "subtitleFontSize": 12,
    "subtitleColor": "#555"
  },
  "width": 340,
  "height": 340,
  "data": {
    "url": "data/chart3_waffle.csv"
  },
  "mark": {
    "type": "image",
    "width": 28,
    "height": 20
  },
  "encoding": {
    "x": {
      "field": "col",
      "type": "ordinal",
      "axis": null,
      "scale": {
        "paddingInner": 0.1,
        "paddingOuter": 0.1
      }
    },
    "y": {
      "field": "row",
      "type": "ordinal",
      "axis": null,
      "sort": "descending",
      "scale": {
        "paddingInner": 0.1,
        "paddingOuter": 0.1
      }
    },
    "url": {
      "field": "flag_url",
      "type": "nominal"
    },
    "opacity": {
      "field": "filled",
      "type": "quantitative",
      "scale": {
        "domain": [
          0,
          1
        ],
        "range": [
          0.12,
          1
        ]
      },
      "legend": null
    },
    "tooltip": [
      {
        "field": "continent",
        "title": "Continent"
      },
      {
        "field": "flag_country",
        "title": "Represents"
      },
      {
        "field": "pct",
        "title": "Continent share (%)",
        "format": ".1f"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "font": "DM Sans"
  }
}