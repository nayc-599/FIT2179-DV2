{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Total emigrant departures by state and territory",
    "subtitle": "Sum of all countries of birth, 2005 to 2025",
    "font": "DM Sans",
    "subtitleFontSize": 12,
    "subtitleColor": "#b8d0e8"
  },
  "width": 550,
  "height": 420,
  "projection": {
    "type": "conicEqualArea",
    "parallels": [-18, -36],
    "rotate": [-134, 0],
    "center": [0, -27],
    "scale": 750
  },
  "data": {
    "url": "data/australian-states.json",
    "format": {"type": "json", "property": "features"}
  },
  "transform": [
    {
      "lookup": "properties.STATE_NAME",
      "from": {
        "data": {"url": "data/chart7_choropleth.csv"},
        "key": "state_name",
        "fields": ["departures", "state", "longitude", "latitude"]
      }
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 0.8
      },
      "encoding": {
        "color": {
          "field": "departures",
          "type": "quantitative",
          "title": "Total departures",
          "scale": {
            "type": "log",
            "scheme": "blues"
          },
          "legend": {
            "format": ",.0f",
            "titleFontSize": 11,
            "labelFontSize": 10
          }
        },
        "tooltip": [
          {"field": "properties.STATE_NAME", "title": "State"},
          {"field": "departures", "title": "Total departures", "format": ","}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "fontSize": 11,
        "fontWeight": 600,
        "fill": "#ffffff",
        "align": "center",
        "baseline": "middle"
      },
      "encoding": {
        "longitude": {"field": "longitude", "type": "quantitative"},
        "latitude": {"field": "latitude", "type": "quantitative"},
        "text": {"field": "state"},
        "tooltip": [
          {"field": "properties.STATE_NAME", "title": "State"},
          {"field": "departures", "title": "Total departures", "format": ","}
        ]
      }
    }
  ],
  "config": {
    "background": "transparent",
    "view": {"stroke": null},
    "font": "DM Sans",
    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 13,
      "labelColor": "#b8d0e8",
      "titleColor": "#f0f6ff",
      "gridColor": "rgba(255,255,255,0.08)",
      "domainColor": "rgba(255,255,255,0.15)",
      "tickColor": "rgba(255,255,255,0.15)"
    },
    "legend": {
      "labelColor": "#f0f6ff",
      "titleColor": "#f0f6ff",
      "labelFontSize": 13,
      "titleFontSize": 14
    },
    "title": {
      "color": "#f0f6ff",
      "subtitleColor": "#b8d0e8",
      "fontSize": 15,
      "subtitleFontSize": 13
    }
  }
}