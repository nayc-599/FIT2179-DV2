{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Departures vs Remittances \u2014 by country",
    "subtitle": "Each bubble = one country. Size = population. Colour = continent. Hover for details.",
    "font": "DM Sans",
    "subtitleFontSize": 12,
    "subtitleColor": "#b8d0e8"
  },
  "width": 880,
  "height": 430,
  "data": {"url": "data/chart17_scatter.csv"},
  "params": [
    {"name": "search_query", "value": ""}
  ],
  "layer": [
    {
      "params": [
        {
          "name": "scatter_hover",
          "select": {"type": "point", "on": "mouseover", "clear": "mouseout"}
        },
        {
          "name": "continent_filter",
          "select": {
            "type": "point",
            "fields": ["continent"]
          },
          "bind": "legend"
        },
        {
          "name": "grid",
          "select": "interval",
          "bind": "scales"
        }
      ],
      "mark": {"type": "point", "filled": true, "stroke": "#fff", "strokeWidth": 0.8},
      "encoding": {
        "x": {
          "field": "departures",
          "type": "quantitative",
          "title": "Total departures from Australia (2004\u201325)",
          "axis": {"format": "~s"},
          "scale": {"type": "log", "domain": [100, 800000]}
        },
        "y": {
          "field": "remittances_aud",
          "type": "quantitative",
          "title": "Remittances received (A$, latest year)",
          "axis": {"format": "~s"},
          "scale": {"type": "log", "domain": [500000, 1000000000000]}
        },
        "size": {
          "field": "population_millions",
          "type": "quantitative",
          "scale": {"range": [50, 3000]},
          "legend": null
        },
        "color": {
          "field": "continent",
          "type": "nominal",
          "title": "Continent",
          "legend": {"orient": "right"},
          "scale": {
            "domain": ["Asia","Europe","Oceania","Americas","Africa","Middle East"],
            "range": ["#ff6eb4","#54a0ff","#16a085","#a78bfa","#d35400","#d4ac0d"]
          }
        },
        "opacity": {
          "condition": [
            {"test": "search_query !== '' && indexof(lower(datum.display_country), search_query) < 0", "value": 0.05},
            {"param": "continent_filter", "empty": true, "value": 0.8},
            {"param": "continent_filter", "empty": false, "value": 1}
          ],
          "value": 0.8
        },
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "continent", "title": "Continent"},
          {"field": "departures", "title": "Total departures", "format": ","},
          {"field": "remittances_aud", "title": "Remittances (A$)", "format": "~s"},
          {"field": "population_millions", "title": "Population (M)", "format": ".1f"}
        ]
      }
    },
    {
      "mark": {"type": "text", "dy": -14, "fontSize": 10, "fontWeight": "bold"},
      "encoding": {
        "x": {"field": "departures", "type": "quantitative", "scale": {"type": "log"}},
        "y": {"field": "remittances_aud", "type": "quantitative", "scale": {"type": "log"}},
        "text": {"field": "display_country"},
        "color": {
          "field": "continent",
          "type": "nominal",
          "legend": null,
          "scale": {
            "domain": ["Asia","Europe","Oceania","Americas","Africa","Middle East"],
            "range": ["#ff6eb4","#54a0ff","#16a085","#a78bfa","#d35400","#d4ac0d"]
          }
        },
        "opacity": {
          "condition": [
            {"test": "search_query !== '' && indexof(lower(datum.display_country), search_query) >= 0", "value": 1},
            {"test": "search_query !== ''", "value": 0},
            {"test": "indexof(['Philippines','New Zealand','UK','Indonesia','USA','Mexico','Bangladesh','Pakistan','Japan','Malaysia','Ireland'], datum.display_country) < 0", "value": 0},
            {"param": "continent_filter", "empty": true, "value": 1},
            {"param": "continent_filter", "empty": false, "value": 1}
          ],
          "value": 0
        }
      }
    },
    {
      "data": {"values": [{}]},
      "layer": [
        {
          "mark": {
            "type": "rect",
            "x": 560, "y": 280, "x2": 870, "y2": 385,
            "fill": "rgba(93,173,226,0.15)",
            "stroke": "#5dade2",
            "strokeWidth": 1.5,
            "cornerRadius": 6,
            "opacity": 0.95
          }
        },
        {"mark": {"type": "text", "x": 715, "y": 305, "fontSize": 14, "fontWeight": "bold", "color": "#5dade2", "text": "High departures, low remittances"}},
        {"mark": {"type": "text", "x": 715, "y": 325, "fontSize": 12, "color": "#c8d8e8", "text": "Countries like New Zealand, UK & Ireland"}},
        {"mark": {"type": "text", "x": 715, "y": 342, "fontSize": 12, "color": "#c8d8e8", "text": "send many emigrants from Australia"}},
        {"mark": {"type": "text", "x": 715, "y": 359, "fontSize": 12, "color": "#c8d8e8", "text": "but receive relatively little in remittances"}}
      ]
    }
  ],
  "config": {
    "background": "transparent",
    "view": {"stroke": null},
    "font": "DM Sans",
    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 13,
      "labelColor": "#b8d0e8",
      "titleColor": "#f0f6ff",
      "gridColor": "rgba(255,255,255,0.08)",
      "domainColor": "rgba(255,255,255,0.15)",
      "tickColor": "rgba(255,255,255,0.15)"
    },
    "legend": {
      "labelColor": "#f0f6ff",
      "titleColor": "#f0f6ff",
      "labelFontSize": 13,
      "titleFontSize": 14
    },
    "title": {
      "color": "#f0f6ff",
      "subtitleColor": "#b8d0e8",
      "fontSize": 15,
      "subtitleFontSize": 13
    }
  }
}