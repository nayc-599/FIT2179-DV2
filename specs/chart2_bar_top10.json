{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Top 10 countries of birth for emigrant departures",
    "subtitle": "Total departures from Australia, 2004–05 to 2024–25 (21 years)",
    "font": "DM Sans",
    "subtitleFontSize": 12,
    "subtitleColor": "#555"
  },
  "width": 580,
  "height": 280,
  "data": {"url": "data/chart2_top10_totals.csv"},
  "layer": [
    {
      "mark": {"type": "bar"},
      "encoding": {
        "y": {
          "field": "display_country",
          "type": "nominal",
          "sort": "-x",
          "title": null,
          "axis": {"labelLimit": 120}
        },
        "x": {
          "field": "departures",
          "type": "quantitative",
          "title": "Total departures",
          "axis": {"format": ",.0f"}
        },
        "color": {
          "field": "display_country",
          "type": "nominal",
          "legend": null,
          "scale": {
            "domain": ["China", "UK", "New Zealand", "India", "USA", "Korea South", "Malaysia", "Japan", "Indonesia", "Philippines"],
            "range": ["#E63946", "#1D3557", "#9B72CF", "#E07020", "#7B2D8B", "#F4D03F", "#E76F51", "#E8A0BF", "#8B4513", "#00B4D8"]}
        },
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "departures", "title": "Total departures", "format": ","}
        ]
      }
    },
    {
      "mark": {
        "type": "image",
        "width": 24,
        "height": 16,
        "align": "left",
        "baseline": "middle"
      },
      "encoding": {
        "y": {
          "field": "display_country",
          "type": "nominal",
          "sort": "-x",
          "title": null
        },
        "x": {
          "field": "departures",
          "type": "quantitative"
        },
        "url": {
          "field": "flag_url",
          "type": "nominal"
        },
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "departures", "title": "Total departures", "format": ","}
        ]
      }
    },
    {
      "data": {"values": [{}]},
      "layer": [
        {
          "mark": {
            "type": "rect",
            "x": 230, "y": 165, "x2": 470, "y2": 260,
            "fill": "#eaf4fb",
            "stroke": "#1a5276",
            "strokeWidth": 1.5,
            "cornerRadius": 6,
            "opacity": 0.95
          }
        },
        {
          "mark": {
            "type": "text",
            "x": 350, "y": 190,
            "fontSize": 12, "fontWeight": "bold",
            "color": "#1a5276",
            "text": "Asia dominates the top 10"
          }
        },
        {
          "mark": {
            "type": "text",
            "x": 350, "y": 215,
            "fontSize": 10,
            "color": "#333",
            "text": "7 of the 10 largest emigrant sources"
          }
        },
        {
          "mark": {
            "type": "text",
            "x": 350, "y": 230,
            "fontSize": 10,
            "color": "#333",
            "text": "are in the Asia-Pacific region"
          }
        }
      ]
    }
  ],
  "config": {    "background": "transparent",
"view": {"stroke": null}, "font": "DM Sans"}
}
