{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Top 10 countries of birth for emigrant departures",
    "subtitle": "Total departures from Australia, 2004–05 to 2024–25 (21 years)",
    "font": "DM Sans",
    "subtitleFontSize": 12,
    "subtitleColor": "#555"
  },
  "width": 380,
  "height": 360,
  "data": {"url": "data/chart2_top10_totals.csv"},
  "layer": [
    {
      "mark": {"type": "bar"},
      "encoding": {
        "y": {
          "field": "display_country",
          "type": "nominal",
          "sort": "-x",
          "title": null,
          "axis": {"labelLimit": 120}
        },
        "x": {
          "field": "departures",
          "type": "quantitative",
          "title": "Total departures",
          "axis": {"format": ",.0f"}
        },
        "color": {
          "field": "display_country",
          "type": "nominal",
          "legend": null,
          "scale": {
            "scheme": "tableau10",
            "domain": ["China", "UK", "New Zealand", "India", "USA", "Korea South", "Malaysia", "Japan", "Indonesia", "Philippines"]
          }
        },
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "departures", "title": "Total departures", "format": ","}
        ]
      }
    },
    {
      "mark": {
        "type": "image",
        "width": 24,
        "height": 16,
        "align": "left",
        "baseline": "middle"
      },
      "encoding": {
        "y": {
          "field": "display_country",
          "type": "nominal",
          "sort": "-x",
          "title": null
        },
        "x": {
          "field": "departures",
          "type": "quantitative"
        },
        "url": {
          "field": "flag_url",
          "type": "nominal"
        },
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "departures", "title": "Total departures", "format": ","}
        ]
      }
    }
  ],
  "config": {    "background": "transparent",
"view": {"stroke": null}, "font": "DM Sans"}
}