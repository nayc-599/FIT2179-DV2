{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Top 10 countries of birth for emigrant departures",
    "subtitle": "Total departures from Australia, 2004\u201305 to 2024\u201325 (21 years)",
    "font": "DM Sans",
    "subtitleFontSize": 12,
    "subtitleColor": "#8aa4c0"
  },
  "width": 580,
  "height": 320,
  "data": {"url": "data/chart2_top10_totals.csv"},
  "layer": [
    {
      "mark": {"type": "bar"},
      "encoding": {
        "y": {
          "field": "display_country",
          "type": "nominal",
          "sort": "-x",
          "title": null,
          "axis": {"labelLimit": 120}
        },
        "x": {
          "field": "departures",
          "type": "quantitative",
          "title": "Total departures",
          "axis": {"format": ",.0f"}
        },
        "color": {
          "field": "display_country",
          "type": "nominal",
          "legend": null,
          "scale": {
            "domain": ["China", "UK", "New Zealand", "India", "USA", "Korea South", "Malaysia", "Japan", "Indonesia", "Philippines"],
            "range": ["#E63946", "#2e86de", "#9B72CF", "#E07020", "#a855f7", "#F4D03F", "#E76F51", "#E8A0BF", "#8B4513", "#00B4D8"]}
        },
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "departures", "title": "Total departures", "format": ","}
        ]
      }
    },
    {
      "mark": {
        "type": "image",
        "width": 24,
        "height": 16,
        "align": "left",
        "baseline": "middle"
      },
      "encoding": {
        "y": {
          "field": "display_country",
          "type": "nominal",
          "sort": "-x",
          "title": null
        },
        "x": {
          "field": "departures",
          "type": "quantitative"
        },
        "url": {
          "field": "flag_url",
          "type": "nominal"
        },
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "departures", "title": "Total departures", "format": ","}
        ]
      }
    },
    {
      "data": {"values": [{}]},
      "layer": [
        {
          "mark": {
            "type": "rect",
            "x": 230, "y": 165, "x2": 470, "y2": 260,
            "fill": "rgba(93,173,226,0.15)",
            "stroke": "#2e86de",
            "strokeWidth": 1.5,
            "cornerRadius": 6,
            "opacity": 0.95
          }
        },
        {
          "mark": {
            "type": "text",
            "x": 350, "y": 190,
            "fontSize": 12, "fontWeight": "bold",
            "color": "#2e86de",
            "text": "Asia dominates the top 10"
          }
        },
        {
          "mark": {
            "type": "text",
            "x": 350, "y": 215,
            "fontSize": 10,
            "color": "#e2eaf4",
            "text": "7 of the 10 largest emigrant sources"
          }
        },
        {
          "mark": {
            "type": "text",
            "x": 350, "y": 230,
            "fontSize": 10,
            "color": "#e2eaf4",
            "text": "are in the Asia-Pacific region"
          }
        }
      ]
    }
  ],
  "config": {
    "background": "transparent",
    "view": {"stroke": null},
    "font": "DM Sans",
    "axis": {
      "labelFontSize": 11,
      "titleFontSize": 12,
      "labelColor": "#8aa4c0",
      "titleColor": "#e2eaf4",
      "gridColor": "rgba(255,255,255,0.08)",
      "domainColor": "rgba(255,255,255,0.15)",
      "tickColor": "rgba(255,255,255,0.15)"
    },
    "legend": {
      "labelColor": "#e2eaf4",
      "titleColor": "#e2eaf4"
    },
    "title": {
      "color": "#e2eaf4",
      "subtitleColor": "#8aa4c0"
    }
  }
}
