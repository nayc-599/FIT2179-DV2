{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Net migration by country of birth, 2024–25",
    "subtitle": "Arrivals minus departures. Blue = net gain for Australia; red = net loss.",
    "font": "DM Sans",
    "subtitleFontSize": 12,
    "subtitleColor": "#555"
  },
  "width": 520,
  "height": 360,
  "data": {"url": "data/chart6_net_migration.csv"},
  "layer": [
    {
      "mark": {"type": "rule", "color": "#333", "strokeWidth": 1},
      "encoding": {"x": {"datum": 0}}
    },
    {
      "mark": {"type": "bar"},
      "encoding": {
        "y": {
          "field": "display_country",
          "type": "nominal",
          "title": null,
          "sort": {"field": "net", "order": "descending"}
        },
        "x": {
          "field": "net",
          "type": "quantitative",
          "title": "Net migration (arrivals − departures)",
          "axis": {"format": ",.0f"}
        },
        "color": {
          "field": "net",
          "type": "quantitative",
          "scale": {"domain": [-20000, 60000], "range": ["#c0392b", "#ffffff", "#1a5276"], "nice": false},
          "legend": null
        },
        "tooltip": [
          {"field": "display_country", "title": "Country"},
          {"field": "arrivals", "title": "Arrivals", "format": ","},
          {"field": "departures", "title": "Departures", "format": ","},
          {"field": "net", "title": "Net", "format": ","}
        ]
      }
    }
  ],
  "config": {"background": "transparent","view": {"stroke": null}, "font": "DM Sans"}
}
